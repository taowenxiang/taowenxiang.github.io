{
  "name": "react-vite-tailwind",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "generate-favicon": "node scripts/generate-favicon.mjs",
    "build": "tsc -b && node scripts/generate-favicon.mjs && vite build --outDir dist",
    "lint": "npx biome lint --write && npx tsc --noEmit",
    "format": "npx biome format --write",
    "preview": "vite preview"
  },
  "dependencies": {
    "framer-motion": "^12.36.0",
    "lucide-react": "^0.514.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/react": "^18.3.22",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.5.0",
    "autoprefixer": "^10.4.21",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.3",
    "vite": "^6.3.5"
  }
}
